<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- Use YARN to run MapReduce jobs -->
  <property>
    <name>mapreduce.framework.name</name>
    <value>yarn</value>
  </property>

  <!-- Classpath for MR jobs (where Hadoop jars are found) -->
  <property>
    <name>mapreduce.application.classpath</name>
    <value>/opt/hadoop/etc/hadoop,/opt/hadoop/share/hadoop/common/*,/opt/hadoop/share/hadoop/common/lib/*,/opt/hadoop/share/hadoop/hdfs/*,/opt/hadoop/share/hadoop/hdfs/lib/*,/opt/hadoop/share/hadoop/yarn/*,/opt/hadoop/share/hadoop/yarn/lib/*,/opt/hadoop/share/hadoop/mapreduce/*,/opt/hadoop/share/hadoop/mapreduce/lib/*</value>
  </property>

  <!-- Env for MR ApplicationMaster (fixes container startup issues) -->
  <property>
    <name>yarn.app.mapreduce.am.env</name>
    <value>HADOOP_MAPRED_HOME=/opt/hadoop</value>
  </property>

  <!-- Env for MR containers -->
  <property>
    <name>mapreduce.admin.user.env</name>
    <value>HADOOP_MAPRED_HOME=/opt/hadoop</value>
  </property>

  <!-- Memory per mapper & Reducer -->
  
  <property>
    <name>mapreduce.map.memory.mb</name>
    <value>512</value>
  </property>

  <property>
    <name>mapreduce.reduce.memory.mb</name>
    <value>512</value>
  </property>

  <property>
    <name>mapreduce.map.java.opts</name>
    <value>-Xmx800m</value>
  </property>

  <property>
    <name>mapreduce.reduce.java.opts</name>
    <value>-Xmx800m</value>
  </property>

</configuration>