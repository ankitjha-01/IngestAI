<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ResourceManager host -->
  <property>
    <name>yarn.resourcemanager.hostname</name>
    <value>master-node</value>
  </property>

  <!-- RM RPC endpoint -->
  <property>
    <name>yarn.resourcemanager.address</name>
    <value>master-node:8032</value>
  </property>

  <!-- Scheduler endpoint -->
  <property>
    <name>yarn.resourcemanager.scheduler.address</name>
    <value>master-node:8030</value>
  </property>

  <!-- NodeManager → RM heartbeat -->
  <property>
    <name>yarn.resourcemanager.resource-tracker.address</name>
    <value>master-node:8031</value>
  </property>

  <!-- Enable MR shuffle service -->
  <property>
    <name>yarn.nodemanager.aux-services</name>
    <value>mapreduce_shuffle</value>
  </property>

  <!-- Shuffle handler class -->
  <property>
    <name>yarn.nodemanager.aux-services.mapreduce.shuffle.class</name>
    <value>org.apache.hadoop.mapred.ShuffleHandler</value>
  </property>

  <!-- Env vars allowed in containers -->
  <property>
    <name>yarn.nodemanager.env-whitelist</name>
    <value>JAVA_HOME,HADOOP_COMMON_HOME,HADOOP_HDFS_HOME,HADOOP_CONF_DIR,CLASSPATH_PREPEND_DISTCACHE,HADOOP_YARN_HOME,HADOOP_MAPRED_HOME</value>
  </property>

  <!-- Total memory per worker node -->
  <property>
    <name>yarn.nodemanager.resource.memory-mb</name>
    <value>2048</value>
  </property>

  <!-- Total CPU cores per worker node -->
  <property>
    <name>yarn.nodemanager.resource.cpu-vcores</name>
    <value>4</value>
  </property>

  <!-- Min container size for Hive job -->
  <property>
    <name>yarn.scheduler.minimum-allocation-mb</name>
    <value>512</value>
  </property>

  <!-- Max container size for Hive job -->
  <property>
    <name>yarn.scheduler.maximum-allocation-mb</name>
    <value>2048</value>
  </property>

  <!-- Classpath for YARN containers -->
  <property>
    <name>yarn.application.classpath</name>
    <value>/opt/hadoop/etc/hadoop,/opt/hadoop/share/hadoop/common/*,/opt/hadoop/share/hadoop/common/lib/*,/opt/hadoop/share/hadoop/hdfs/*,/opt/hadoop/share/hadoop/hdfs/lib/*,/opt/hadoop/share/hadoop/yarn/*,/opt/hadoop/share/hadoop/yarn/lib/*,/opt/hadoop/share/hadoop/mapreduce/*,/opt/hadoop/share/hadoop/mapreduce/lib/*</value>
  </property>

  <!-- Disable virtual memory checks -->
  <property>
    <name>yarn.nodemanager.vmem-check-enabled</name>
    <value>false</value>
  </property>

  <!-- Disable physical memory checks -->
  <property>
    <name>yarn.nodemanager.pmem-check-enabled</name>
    <value>false</value>
  </property>

  <!-- Delay container log deletion (debugging) -->
  <property>
    <name>yarn.nodemanager.delete.debug-delay-sec</name>
    <value>600</value>
  </property>

</configuration>